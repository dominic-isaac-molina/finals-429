{
  "name": "tamper-proof-document-verification",
  "version": "2.0.0",
  "description": "Browser-direct dApp for hashing documents and registering them on a public Ethereum-compatible testnet.",
  "main": "frontend/index.html",
  "scripts": {
    "compile": "HOME=.hardhat-home hardhat compile",
    "node": "HOME=.hardhat-home hardhat node",
    "deploy:localhost": "HOME=.hardhat-home hardhat run scripts/deploy.js --network localhost",
    "deploy:amoy": "HOME=.hardhat-home hardhat run scripts/deploy.js --network amoy",
    "serve": "npx --yes serve frontend -l 3001",
    "test": "HOME=.hardhat-home hardhat test test/DocumentRegistry.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "chai": "^4.5.0",
    "hardhat": "^2.22.19"
  }
}
