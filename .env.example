# Copy this file to .env and fill in your values. Never commit .env.

# Private key (64 hex chars) of the throwaway wallet that deploys the contract
# AND signs every register/remove transaction for visitors. This wallet only
# needs a tiny amount of Amoy testnet MATIC (free from a faucet). Do NOT use
# a private key that holds real money — make a fresh wallet just for this.
#
# To generate one without installing MetaMask:
#   node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
PRIVATE_KEY=

# Optional. Public Amoy RPC works fine for low traffic. If you hit rate
# limits, sign up for a free Alchemy or Infura key and paste the HTTPS URL.
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
