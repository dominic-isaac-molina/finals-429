# Copy this file to .env and fill in your values. Never commit .env.

# Private key of the wallet that will deploy the contract. This wallet only
# needs a tiny amount of Amoy testnet MATIC (free from a faucet). Do NOT use a
# private key that holds real money — make a fresh wallet just for testnet work.
PRIVATE_KEY=

# Public Amoy RPC. The default below is free and works fine, but if you hit
# rate limits, sign up for a free Alchemy or Infura key.
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
